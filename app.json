{
  "expo": {
    "name": "KaviAI",
    "slug": "kaviai",
    "scheme": "kaviai",
    "extra": {
      "verificationSuccessUrl": "https://project-s0syc-chta4448s-ishankreddys-projects.vercel.app/"
    },
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kaviai.app"
    },
    "android": {
      "package": "com.kaviai.app",
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/android-icon-foreground.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store"
    ]
  }
}
